# ───────────────────────────────────────────────────────────────
# MathVision environment variables — copy to .env and fill in.
# Never commit .env. (Render uses Environment Groups in production.)
# ───────────────────────────────────────────────────────────────

# --- Server ---
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# --- Database (MongoDB Atlas in prod, local mongod in dev) ---
MONGODB_URI=mongodb://127.0.0.1:27017/mathvision

# --- Auth ---
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d

# --- AI / OCR providers (cost-no-object accuracy) ---
OPENAI_API_KEY=
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# --- Verifier service (Python/SymPy) ---
VERIFIER_URL=http://127.0.0.1:8000
VERIFIER_SERVICE_KEY=dev-only-change-me

# --- Images (Cloudinary; or use GridFS and leave blank) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- OAuth (Phase 0+: email works without these) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=

# --- Client (Vite — only VITE_* vars are exposed to the browser) ---
VITE_API_BASE=/api
VITE_APP_NAME=MathVision
